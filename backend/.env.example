# ── Database ──────────────────────────────────────────────────────────────────
# Neon (or any PostgreSQL) connection string.
# Format: postgresql://<user>:<password>@<host>/<database>?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be a long, random string. Never commit the real value.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# Optional: token lifetime. Defaults to 7d if omitted.
# Accepts zeit/ms format: 60s, 15m, 2h, 7d, 30d
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────────
# Port the Express server listens on. Defaults to 5000.
PORT=5000
